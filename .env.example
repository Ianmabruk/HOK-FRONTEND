# Copy this file to .env.local for local development overrides.
# In Netlify: Site configuration → Environment variables → Add the variable below.

# Production frontend setting: point this to your deployed Flask backend API root
# with no trailing slash, for example:
# VITE_API_URL=https://your-backend.onrender.com/api
#
# Do not use a GitHub repository URL here. This must be the live backend origin.
# Wrong: https://github.com/Ianmabruk/HOK-backend.git
# Right: https://your-backend.onrender.com/api
#
# Leave it unset locally when the Vite dev proxy is handling /api.
VITE_API_URL=https://your-backend.example.com
